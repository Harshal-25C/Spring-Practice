<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="
        http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd">

    <bean class = "in.sp.beans.Address" id = "addrId">
        <constructor-arg value="385" />
        <constructor-arg value="Mumbai" />
        <constructor-arg value="460241" />
    </bean>
    
    <bean class = "in.sp.beans.Student" id = "stuId">
        <constructor-arg value="Anvii" />
        <constructor-arg value="101" />
        <constructor-arg ref="addrId" />
    </bean>

</beans>