<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="
        http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd">

    <bean class = "in.sp.beans.Address" id = "addrId">
        <property name="houseNo" value = "385"></property>
        <property name="city" value = "Mumabi"></property>
        <property name="pincode" value = "450331"></property>
    </bean>
    
    <bean class = "in.sp.beans.Student" id = "stuId">
        <property name="name" value = "Harshal"></property>
        <property name="rollNo" value = "101"></property>
        <property name="address" ref = "addrId"></property>
    </bean>

</beans>